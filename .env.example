# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# AWS Bedrock
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
# Nova model IDs: amazon.nova-micro-v1:0 | amazon.nova-lite-v1:0 | amazon.nova-pro-v1:0
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# OCR provider: "nova" (default, uses Bedrock) | "tesseract" (local fallback)
OCR_PROVIDER=nova
# Windows only — full path to tesseract.exe (required when OCR_PROVIDER=tesseract)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Loan agreement PDF settings
LOAN_ANNUAL_RATE_PCT=8.0

# JWT — paths are relative to the project root
JWT_PRIVATE_KEY_PATH=certs/leaf.key.pem
JWT_PUBLIC_CERT_PATH=certs/leaf.cert.pem

# Database
DB_PATH=vaultiq.db

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
